# =================== Penyedia AI ===================
# Pilih penyedia AI untuk fitur "ngobrol dengan asisten koperasi":
#   groq       -> default, gratis & cepat (butuh GROQ_API_KEY)
#   anthropic  -> Claude (butuh ANTHROPIC_API_KEY)
AI_PROVIDER=groq

# =================== Groq (default) ===================
# Ambil API key gratis di https://console.groq.com/keys
# Boleh dikosongkan dulu -> fitur ngobrol AI nonaktif, bot tetap jalan mode menu.
GROQ_API_KEY=
# Model Groq. Lihat daftar di https://console.groq.com/docs/models
#   llama-3.3-70b-versatile  -> pintar & serba bisa (default)
#   llama-3.1-8b-instant     -> paling cepat & ringan
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# =================== Claude AI (Anthropic) — opsional ===================
# Dipakai hanya kalau AI_PROVIDER=anthropic.
# Ambil API key di https://console.anthropic.com  (Settings > API Keys)
ANTHROPIC_API_KEY=

# Model Claude yang dipakai. Ganti sesuai kebutuhan biaya vs kualitas:
#   claude-opus-4-8    -> paling pintar   (~$5 / $25 per 1 juta token)
#   claude-sonnet-4-6  -> seimbang        (~$3 / $15 per 1 juta token)
#   claude-haiku-4-5   -> tercepat+termurah (~$1 / $5 per 1 juta token)  << rekomendasi buat CS bot
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024

# =================== Supabase (Database bersama bot + dashboard) ===================
# Sumber data bersama untuk bot & dashboard web. KOSONG -> bot pakai data dummy
# in-memory seperti biasa (fallback aman, tidak crash).
# Ambil di Supabase Dashboard > Project Settings > API.
SUPABASE_URL=
# PENTING (OWASP): ini SECRET server-side. HANYA di sini (bot), JANGAN pernah
# ditaruh di folder dashboard/ atau kode frontend. service_role bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# =================== SIMKOPDES (Aktivasi Anggota) ===================
# Endpoint API pendaftaran/aktivasi ke database utama pemerintah (SIMKOPDES).
# KOSONG  -> pakai adapter DUMMY (data in-memory, no. anggota palsu) untuk demo.
# DIISI   -> data aktivasi otomatis di-POST ke endpoint ini (tanpa ubah kode alur).
SIMKOPDES_API_URL=
SIMKOPDES_API_KEY=

# =================== WhatsApp (Baileys) ===================
# Folder penyimpanan sesi login WA (hasil scan QR). Sudah masuk .gitignore.
WA_AUTH_DIR=auth
# Balas pesan grup juga? (default: false, cuma chat pribadi)
WA_HANDLE_GROUPS=false

# =================== Fitur Campaign (proaktif) ===================
# Nomor admin yang boleh memicu broadcast (format 62..., pisah koma). Kosong = fitur push nonaktif.
ADMIN_NUMBERS=
# Nomor tujuan broadcast demo — nomor asli yang kamu kontrol untuk uji "push".
# Contoh: BROADCAST_TARGETS=6281234567890,6289876543210
BROADCAST_TARGETS=

# =================== Batas & Keamanan ===================
# Panjang maksimum pesan masuk yang diproses (anti-abuse)
MAX_INBOUND_CHARS=2000
# Maksimum pesan per user per menit (rate limit, anti-spam & hemat biaya AI)
RATE_MAX_PER_MIN=15
# Berapa giliran percakapan (user+bot) yang diingat per user
HISTORY_TURNS=6
# Sesi user dianggap kadaluarsa setelah tidak aktif sekian menit
SESSION_TTL_MINUTES=60

# =================== Logging ===================
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn
