# Salin file ini jadi .env, lalu isi sesuai panduan di bawah.
# JANGAN PERNAH commit file .env (sudah di-.gitignore). Repo ini publik.
#
# ARSITEKTUR YANG DIREKOMENDASIKAN: 1 DATABASE, bukan 2.
# Aplikasi (dan bot WA tim) SEHARUSNYA connect ke SATU database saja: database
# milik tim sendiri (mis. Supabase yang sudah dipakai bot WA). Supaya database
# itu juga berisi 27 tabel dataset resmi SimkopDes, jalankan SEKALI:
#   npm run db:copy-dataset
# Ini menyalin data dari Shared Database panitia (SRC_DB_*) ke database sendiri
# (DB_*). Setelah itu SRC_DB_* tidak dipakai lagi — boleh dihapus dari .env.
# Alasan ini diperbolehkan & dianjurkan: lihat docs/HACKATHON-STRATEGY.md §6C.

# ============================================================
# DB_* — Database TUJUAN akhir (milik tim sendiri, mis. Supabase yang
# sudah dipakai bot WA). INI yang dipakai aplikasi (dataset.ts, edigdev.ts)
# setiap kali jalan — bukan Shared Database panitia.
# ============================================================
DB_HOST=
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=
DB_PASSWORD=
DB_SSL=true

# Prefix untuk tabel milik aplikasi EdigDaya sendiri (registrasi, e-RAT, dst).
# Jika sudah pakai database sendiri (bukan Shared DB panitia), prefix ini
# hanya soal penamaan/kerapian — tidak wajib lagi seperti saat masih di Shared DB.
TABLE_PREFIX=edigdev_

# ============================================================
# SRC_DB_* — Shared Database PANITIA. Hanya dipakai SEKALI oleh
# `npm run db:copy-dataset` untuk menyalin 27 tabel dataset ke DB_* di atas.
# Isi dari email panitia ("Google Cloud Credit dan Shared Database Server",
# 10 Juli 2026) atau grup WhatsApp resmi peserta. Boleh dihapus setelah dipakai.
# ============================================================
SRC_DB_HOST=
SRC_DB_PORT=5432
SRC_DB_DATABASE=hackathon_2026
SRC_DB_USERNAME=
SRC_DB_PASSWORD=
SRC_DB_SSL=false

# Mode preview: set true untuk lihat UI Dashboard tanpa koneksi database nyata
# (angka contoh = hasil query nyata tim 10 Juli 2026, nama wilayah = placeholder).
# Berguna utk latihan demo/pitch atau cadangan jika database bermasalah saat hari-H.
MOCK_DATA=false

# WhatsApp Cloud API (Meta) — untuk webhook & kirim pesan. Isi setelah setup Meta App / sandbox.
WA_VERIFY_TOKEN=edigdaya-dev-token
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# Anthropic API (opsional) — untuk endpoint rekomendasi AI. Tanpa ini, fallback rule-based aktif.
ANTHROPIC_API_KEY=
