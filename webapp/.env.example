# Salin file ini jadi .env, lalu isi nilai asli dari:
# - Email panitia perihal "Google Cloud Credit dan Shared Database Server" (10 Juli 2026), ATAU
# - Grup WhatsApp resmi peserta
#
# JANGAN PERNAH commit file .env (sudah di-.gitignore). Repo ini publik.

# Kredensial Shared PostgreSQL Database (dari panitia)
DB_HOST=
DB_PORT=5432
DB_DATABASE=hackathon_2026
DB_USERNAME=
DB_PASSWORD=

# Set true jika koneksi mewajibkan SSL (cek dgn tim/panitia jika psql butuh sslmode)
DB_SSL=false

# Prefix WAJIB untuk semua tabel milik aplikasi EdigDaya (agar tidak tabrakan dgn 99 tim lain)
TABLE_PREFIX=edigdev_

# Mode preview: set true untuk lihat UI Dashboard tanpa koneksi database nyata
# (angka contoh = hasil query nyata tim 10 Juli 2026, nama wilayah = placeholder).
# Berguna utk latihan demo/pitch atau cadangan jika Shared Database bermasalah saat hari-H.
MOCK_DATA=false

# WhatsApp Cloud API (Meta) — untuk webhook & kirim pesan. Isi setelah setup Meta App / sandbox.
WA_VERIFY_TOKEN=edigdaya-dev-token
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# Anthropic API (opsional) — untuk endpoint rekomendasi AI. Tanpa ini, fallback rule-based aktif.
ANTHROPIC_API_KEY=
